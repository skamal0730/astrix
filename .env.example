# Secrets and deployment IDs are required. Token/router defaults come from config/testnet.json.
#
# Hedera operator account for HCS interactions
HEDERA_OPERATOR_ID=0.0.xxxxx
HEDERA_OPERATOR_KEY=302e020100300506032b657004220420...

# Optional submit key for private topic creation
HCS_SUBMIT_KEY=

# Existing topic id for publish/solver flow; leave empty to create
HCS_TOPIC_ID=

# Hedera testnet JSON-RPC endpoint for contract settlement
HEDERA_RPC_URL=https://testnet.hashio.io/api

# EVM private key used by solver to call settle()
SOLVER_PRIVATE_KEY=0xabc123...

# Deployed settlement contract EVM address
SETTLEMENT_CONTRACT=0x0000000000000000000000000000000000000000

# Intent defaults (HBAR/USDC on Hedera testnet)
CHAIN_ID=296
# Defaults below match config/testnet.json when unset
WHBAR_TOKEN=
USDC_TOKEN=
ROUTER_ADDRESS=
POOL_FEE=3000
MIN_PROFIT_BPS=0

# Backend runtime
PORT=3001
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com/api/v1
USDC_TOKEN_ID=

# Optional: ping solver /health when users hit the API (wakes Render free-tier solver)
SOLVER_HEALTH_URL=https://your-solver.onrender.com
# SOLVER_WAKE_COOLDOWN_MS=60000
# SOLVER_WAKE_TIMEOUT_MS=2500
